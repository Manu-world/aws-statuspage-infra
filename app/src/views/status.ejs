<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>StatusPage</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-slate-950 text-slate-100 min-h-screen">
  <main class="max-w-3xl mx-auto px-4 py-10 space-y-8">
    <header class="space-y-2">
      <p class="text-sm uppercase tracking-widest text-slate-400">StatusPage</p>
      <h1 class="text-3xl font-semibold">Service status</h1>
      <div class="rounded-lg border border-slate-700 bg-slate-900 px-4 py-3">
        <p class="text-lg font-medium"><%= overallLabel %></p>
        <p class="text-sm text-slate-400">Overall: <%= overall %></p>
      </div>
    </header>

    <section class="space-y-3">
      <h2 class="text-xl font-medium">Services</h2>
      <ul class="divide-y divide-slate-800 rounded-lg border border-slate-800 bg-slate-900">
        <% services.forEach(function(service) { %>
          <li class="flex items-center justify-between px-4 py-3">
            <div>
              <p class="font-medium"><%= service.name %></p>
              <% if (service.description) { %>
                <p class="text-sm text-slate-400"><%= service.description %></p>
              <% } %>
            </div>
            <span class="text-sm rounded-full px-3 py-1 bg-slate-800 border border-slate-700">
              <%= service.status %>
            </span>
          </li>
        <% }) %>
      </ul>
    </section>

    <section class="space-y-3">
      <h2 class="text-xl font-medium">Active incidents</h2>
      <% if (activeIncidents.length === 0) { %>
        <p class="text-slate-400">No active incidents.</p>
      <% } else { %>
        <div class="space-y-4">
          <% activeIncidents.forEach(function(incident) { %>
            <article class="rounded-lg border border-slate-800 bg-slate-900 p-4 space-y-3">
              <div class="flex items-start justify-between gap-4">
                <div>
                  <h3 class="font-medium"><%= incident.title %></h3>
                  <p class="text-sm text-slate-400">
                    <%= incident.service.name %> · <%= incident.severity %> · <%= incident.status %>
                  </p>
                </div>
              </div>
              <ol class="space-y-2 border-l border-slate-700 pl-4">
                <% incident.updates.forEach(function(update) { %>
                  <li>
                    <p class="text-sm"><%= update.message %></p>
                    <p class="text-xs text-slate-500">
                      <%= update.statusAtUpdate %> · <%= update.createdAt.toISOString() %>
                    </p>
                  </li>
                <% }) %>
              </ol>
            </article>
          <% }) %>
        </div>
      <% } %>
    </section>
  </main>
</body>
</html>
